{
  "name": "productivity-assistant",
  "version": "3.0.0",
  "description": "Email & calendar automation using Claude Code CLI with Apple Mail and Apple Calendar",
  "type": "module",
  "scripts": {
    "process": "tsx src/index.ts",
    "digest": "tsx src/digest/index.ts",
    "digest:html": "tsx src/digest/index.ts --format html",
    "digest:md": "tsx src/digest/index.ts --format markdown",
    "calendar": "tsx src/calendar/index.ts analyze",
    "calendar:analyze": "tsx src/calendar/index.ts analyze",
    "calendar:review": "tsx src/calendar/index.ts review",
    "calendar:gaps": "tsx src/calendar/index.ts gaps",
    "calendar:suggest": "tsx src/calendar/index.ts suggest",
    "build": "tsc --noEmit",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
