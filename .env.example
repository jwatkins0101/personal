# Gmail OAuth Credentials
# Get these from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable Gmail API
# 3. Create OAuth 2.0 credentials (Desktop app)
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# Outlook/Microsoft 365 OAuth Credentials
# Get these from Azure Portal:
# 1. Go to https://portal.azure.com/
# 2. Navigate to "Azure Active Directory" -> "App registrations"
# 3. Create a new registration with redirect URI: http://localhost:3001/auth/callback
# 4. Add API permissions: Microsoft Graph -> Mail.ReadWrite, User.Read
OUTLOOK_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret_here
# Use "common" for multi-tenant, or your specific tenant ID
OUTLOOK_TENANT_ID=common

# Optional: Maximum emails to process per run (default: 20)
MAX_EMAILS_PER_RUN=20
